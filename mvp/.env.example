# --- Database (Supabase Session Pooler) ---
# Project Settings → Database → Connection string → Session pooler (port 5432) → URI
# URL-encode special chars in password: @ → %40, # → %23
DATABASE_URL=postgresql+psycopg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WEBHOOK_URL=https://your-app.vercel.app/twilio/whatsapp
VALIDATE_TWILIO_SIGNATURE=true

# --- Duffel (https://duffel.com) ---
# Test key starts with duffel_test_..., live key with duffel_live_...
DUFFEL_API_KEY=

# --- LLM (OpenAI-compatible) ---
# Alternatives: Groq (OPENAI_BASE_URL=https://api.groq.com/openai/v1, MODEL=llama-3.1-8b-instant)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Behaviour ---
ALERT_COOLDOWN_HOURS=6
DEFAULT_CURRENCY=INR
MAX_WATCHES_PER_USER=10
MAX_SAMPLES_PER_WATCH=5
PRICE_SAMPLE_RETENTION_DAYS=30

# --- Secrets ---
# CRON_SECRET: set in Vercel env vars — Vercel sends this as Authorization: Bearer header on cron calls
CRON_SECRET=
# DEBUG_SECRET: enables /debug/simulate endpoint — leave empty in production
DEBUG_SECRET=
